with "sha3_ada";

project Test_SHA3 is

   for Main use ("test_sha3.adb");
   for Object_Dir use "obj";
   for Source_Dirs use ("src");
   for Languages use ("Ada");

   package Compiler is
      for Switches ("Ada") use
        ("-g", "-O2", "-gnatwa", "-gnatW8", "-gnatyM120",
         "-gnat2022");
   end Compiler;

   package Linker is
      for Switches ("Ada") use
        ("-L" & External ("SDK_LIB",
           "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/lib"));
   end Linker;

end Test_SHA3;
